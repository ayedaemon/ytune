# ==============================================================================
# yTune Environment Variables Configuration Example
# ==============================================================================
# Copy this file to '.env' and adjust the values as needed for your environment:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# Connection string for the PostgreSQL database.
# Default (local dev): postgresql://ytmusic:password@localhost:5432/ytmusic_db
# Default (Docker Compose): postgresql://ytmusic:password@db:5432/ytmusic_db
DATABASE_URL=postgresql://ytmusic:password@localhost:5432/ytmusic_db

# Maximum number of database connections in the connection pool.
# Default: 10
DB_MAX_POOL_SIZE=10

# Minimum number of database connections in the connection pool.
# Default: 2
DB_MIN_POOL_SIZE=2

# Docker Compose PostgreSQL service setup (only used if running via docker compose)
POSTGRES_USER=ytmusic
POSTGRES_PASSWORD=password
POSTGRES_DB=ytmusic_db


# ------------------------------------------------------------------------------
# 2. General / Shared Configurations
# ------------------------------------------------------------------------------
# Root directory where downloaded audio tracks and files are stored.
# Inside Docker container, this is typically mapped to '/storage'.
# Default: /storage
STORAGE_ROOT=/storage

# Logging verbosity level.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# 3. YouTube Music Sync Service (ytm-sync)
# ------------------------------------------------------------------------------
# Path to the JSON authentication credentials file extracted from YouTube Music.
# Default: /app/auth/ytmusic.json
YTM_AUTH_FILE=/app/auth/ytmusic.json


# ------------------------------------------------------------------------------
# 4. YouTube Downloader Service (ytdlp-downloader)
# ------------------------------------------------------------------------------
# Path to the browser cookies file needed for yt-dlp to access YouTube.
# Default: /app/auth/cookies.txt
YTM_COOKIES_FILE=/app/auth/cookies.txt

# Maximum concurrent downloads.
# If unset/blank, the service dynamically sizes concurrency based on the
# container's cgroup limits (~180MB RAM per worker). Set an integer to override.
# Default: (Dynamic)
MAX_CONCURRENT_DOWNLOADS=

# Output audio format for yt-dlp downloads.
# Options: opus, mp3, m4a, aac, flac, wav, vorbis
# Default: mp3
AUDIO_FORMAT=mp3

# Output filename template for downloads (relative to STORAGE_ROOT).
# See: https://github.com/yt-dlp/yt-dlp#output-template
# Default: %(id)s.%(ext)s
DOWNLOAD_OUTTMPL=%(id)s.%(ext)s


# ------------------------------------------------------------------------------
# 5. Librosa Feature Enrichment Service (enrich-librosa)
# ------------------------------------------------------------------------------
# Maximum concurrent workers running Librosa feature extraction.
# If unset/blank, the service dynamically sizes concurrency based on the
# container's cgroup limits (~400MB RAM per worker). Set an integer to override.
# Default: (Dynamic)
LIBROSA_MAX_CONCURRENT_WORKERS=

# Duration in seconds to clip audio files at before Librosa analysis to avoid OOM
# on extremely long files.
# Default: 300
MAX_ANALYSIS_SECONDS=300


# ------------------------------------------------------------------------------
# 6. Audio Embedding Services (embeddings-clap, embeddings-mert)
# ------------------------------------------------------------------------------
# PyTorch computing device for embedding inference.
# Options: cpu, cuda (for NVIDIA GPU), mps (for Apple Silicon GPU)
# Default: cpu
DEVICE=cpu

# Maximum concurrent workers for the CLAP embedding service.
# The CLAP model is not thread-safe for concurrent CPU inference. Keep at 1
# unless running on a GPU with room for more concurrent loads.
# Default: 1
CLAP_MAX_CONCURRENT_WORKERS=1

# Maximum concurrent workers for the MERT embedding service.
# Default: 1
MERT_MAX_CONCURRENT_WORKERS=1

# Duration in seconds to clip audio before model inference to prevent OOM.
# Default: 60
MAX_ANALYSIS_SECONDS=60


# ------------------------------------------------------------------------------
# 7. Suggestion Engine Configuration
# ------------------------------------------------------------------------------
# Number of clusters (k) to partition tracks into for mood clustering (K-Means).
# Default: 8
CLUSTER_K=8

# Number of new rating/enrichment events before a re-clustering run is triggered.
# Default: 10
CLUSTER_TRIGGER_THRESHOLD=10
